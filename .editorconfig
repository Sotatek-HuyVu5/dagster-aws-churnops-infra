root = true

# ─── Default: tất cả file ───────────────────────────────────────────────────
[*]
charset             = utf-8
end_of_line         = lf
indent_style        = space
indent_size         = 2
trim_trailing_whitespace = true
insert_final_newline = true

# ─── Terraform ──────────────────────────────────────────────────────────────
[*.{tf,tfvars}]
indent_size = 2

# ─── YAML (GitHub Actions, Helm values) ─────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ─── JSON ───────────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ─── Markdown ───────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# ─── Shell ──────────────────────────────────────────────────────────────────
[*.sh]
indent_size = 2

# ─── Makefile (yêu cầu tab) ─────────────────────────────────────────────────
[Makefile]
indent_style = tab
